            "temp_amount": "",
            "currency_preference": "INR",  # Default to INR
            "connected_to_admin": None  # Track which admin is connected
        })

def get_user(user_id):
    """Get user document"""
    ensure_user_entry(user_id)
    return users.find_one({"_id": user_id})

def update_user(user_id, data: dict):
    """Update user document"""
    users.update_one({"_id": user_id}, {"$set": data})

# ---------- Connection Management ----------
def connect_user_to_admin(user_id, admin_id):
    """Connect a user to an admin for private messaging"""
    try:
        # Update user's connection
        users.update_one(
            {"_id": user_id},
            {"$set": {"connected_to_admin": admin_id}}
        )
        
        # Update admin's session
        admin_sessions.update_one(
            {"admin_id": admin_id},
            {"$set": {"connected_to_user": user_id, "username": get_user(user_id).get("username", "Unknown")}},
            upsert=True
        )
        
        # Create connection record
        connections.update_one(
            {"user_id": user_id, "admin_id": admin_id},
            {"$set": {
                "user_id": user_id,
                "admin_id": admin_id,
                "connected_at": datetime.datetime.now(),
                "status": "connected"
            }},
            upsert=True
        )
        
        logger.info(f"✅ Connected admin {admin_id} to user {user_id}")
        return True
    except Exception as e:
        logger.error(f"❌ Error connecting admin to user: {e}")
        return False

def disconnect_user(user_id):
    """Disconnect a user from admin"""
    try:
        user = get_user(user_id)
        admin_id = user.get("connected_to_admin")
        
        if admin_id:
            # Update user
            users.update_one(
                {"_id": user_id},
                {"$set": {"connected_to_admin": None}}
            )
            
            # Update admin session
            admin_sessions.update_one(
                {"admin_id": admin_id},
                {"$set": {"connected_to_user": None, "username": None}}
            )
            
            # Update connection record
            connections.update_one(
