# ---------- Helpers ----------
def ensure_user_entry(user_id, username=None):
    """Create user entry if not exists"""
    if not users.find_one({"_id": user_id}):
        users.insert_one({
            "_id": user_id,
            "username": username,
            "balance": 0.0,
            "pending_deposit": None,
