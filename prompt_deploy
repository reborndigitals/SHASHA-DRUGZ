# ---------- Dynamic Country Helpers ----------
def get_countries(platform=None):
    """Get countries for platform"""
    if platform:
        return list(countries_col.find({"platform": platform}, {"_id": 0}))
    return list(countries_col.find({}, {"_id": 0}))

def get_country(platform, name):
    """Get specific country"""
    return countries_col.find_one({"platform": platform, "name": name})

def add_country(platform, name, usdt_price, inr_price, available):
    """Add/update country with dual pricing"""
    countries_col.update_one(
        {"platform": platform, "name": name},
        {"$set": {
            "platform": platform, 
            "name": name, 
            "usdt_price": usdt_price,
            "inr_price": inr_price,
            "available": available
        }},
        upsert=True
    )

def remove_country(platform, name):
    """Remove country"""
    countries_col.delete_one({"platform": platform, "name": name})

def format_price(usdt_price, inr_price):
    """Format price with symbols"""
    return f"₮{usdt_price} / ₹{inr_price}"

def parse_price_input(price_input):
    """Parse price input in format: usdt_price/inr_price"""
    try:
        if '/' in price_input:
            usdt_price, inr_price = price_input.split('/')
            return float(usdt_price.strip()), float(inr_price.strip())
        else:
            # If only one price given, assume it's INR
            return 0.0, float(price_input)
    except ValueError:
        return None, None

