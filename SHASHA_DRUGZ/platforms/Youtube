async def get_public_ip_info():
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get('https://ipapi.co/json/', timeout=10) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    return {
                        'ip': data.get('ip'),
                        'city': data.get('city'),
                        'region': data.get('region'),
                        'country': data.get('country_name'),
                        'org': data.get('org'),
                        'timezone': data.get('timezone')
                    }
    except Exception as e:
        logger.error(f"Failed to fetch IP info: {e}")
    return None

async def get_device_info(page) -> dict:
    """Collect device/browser info via JavaScript execution in Playwright."""
    info = {}
    try:
        info['user_agent'] = await page.evaluate('navigator.userAgent')
    except:
        info['user_agent'] = 'unknown'
    try:
        info['platform'] = await page.evaluate('navigator.platform')
    except:
        info['platform'] = 'unknown'
    try:
        info['language'] = await page.evaluate('navigator.language')
    except:
        info['language'] = 'unknown'
    try:
        info['screen'] = await page.evaluate('`${window.screen.width}x${window.screen.height}`')
    except:
        info['screen'] = 'unknown'
    try:
        info['browser_timezone'] = await page.evaluate('Intl.DateTimeFormat().resolvedOptions().timeZone')
    except:
        info['browser_timezone'] = 'unknown'
    import socket
    info['hostname'] = socket.gethostname()
    info['pid'] = os.getpid()
    info['profile_dir'] = PLAYWRIGHT_PROFILE_DIR
    info['timestamp'] = datetime.datetime.utcnow().isoformat() + 'Z'
    ip_info = await get_public_ip_info()
    if ip_info:
        info.update(ip_info)
    else:
        info['ip'] = 'unknown'
        info['city'] = 'unknown'
        info['country'] = 'unknown'
    return info

# ========== COOKIE VERIFICATION ==========
def verify_cookies_file(filename: str) -> bool:
    """Verify cookies file has proper YouTube cookies in Netscape format"""
    try:
        if not os.path.exists(filename):
            logger.error(f"Cookies file does not exist: {filename}")
            return False

        with open(filename, 'r', encoding='utf-8') as f:
            content = f.read()

        # Check for youtube.com domain
        if 'youtube.com' not in content and '.youtube.com' not in content:
            logger.error("No youtube.com domain in cookies file")
            return False

        # Check for required YouTube cookies
        required_cookies = ['__Secure-YEC', '__Secure-YENID', 'PREF', 'VISITOR_INFO1_LIVE']
        found_cookies = []
        for cookie_name in required_cookies:
            if cookie_name in content:
                found_cookies.append(cookie_name)

        if len(found_cookies) < 2:
            logger.warning(f"Missing important cookies. Found: {found_cookies}")

        # Check format - not JSON
        if content.strip().startswith('{') or '"domain"' in content:
            logger.error("Cookies file appears to be JSON format, not Netscape")
            return False

        # Check for proper Netscape format (tabs between fields)
        lines = content.strip().split('\n')
        valid_lines = 0
        for line in lines:
            if line.startswith('#') or not line.strip():
                continue
            if '\t' not in line:
                logger.error(f"Invalid Netscape format line (no tabs): {line[:100]}")
                return False
            valid_lines += 1

        if valid_lines < 3:
            logger.error(f"Too few valid cookie lines: {valid_lines}")
            return False

        logger.info(f"✅ Cookies file verified: {filename} (found {found_cookies})")
        return True

    except Exception as e:
        logger.error(f"Error verifying cookies file: {e}")
        return False

def is_cookie_file_expired(filepath: str, max_age: int = 172800) -> bool:
    """Check if cookie file is older than max_age (default 2 days)"""
    if os.path.getmtime(filepath) < time.time() - max_age:
        logger.info(f"Cookie file {filepath} is older than {max_age/3600:.1f} hours, considering expired.")
        return True
    return False

# ========== WRITE NETSCAPE COOKIES ==========
def write_netscape_cookies(cookies, filename):
    """Write cookies in STRICTLY CORRECT Netscape format for yt-dlp"""
    with open(filename, "w", newline='', encoding='utf-8') as f:
        f.write("# Netscape HTTP Cookie File\n")
        f.write("# This file was generated by YouTube Bot\n")
        f.write("# https://www.youtube.com\n\n")

        for cookie in cookies:
            try:
                domain = cookie.get('domain', '')
                if not domain:
                    continue

                # Skip irrelevant domains
                if 'gstatic.com' in domain or 'doubleclick.net' in domain:
                    continue

                # Get expiration (handle various formats)
                expires = cookie.get('expires', cookie.get('expiry', 0))
                if expires == 0:
                    expires = int(time.time()) + 86400 * 365  # 1 year default
                elif expires > 1000000000000:  # Probably milliseconds
                    expires = int(expires / 1000)

                # Determine flag based on domain format
                if domain.startswith('.'):
                    flag = "TRUE"   # domain cookie
                else:
                    flag = "FALSE"  # host-only cookie

                path = cookie.get('path', '/')
                secure = "TRUE" if cookie.get('secure', False) else "FALSE"
                expires_str = str(int(expires))
                name = cookie.get('name', '')
                value = cookie.get('value', '')

                if not name or not value:
                    continue

                # Handle special characters in value
                if '\t' in value or '\n' in value:
                    value = value.replace('\t', ' ').replace('\n', ' ')

                # Write EXACTLY 7 tab-separated fields
                f.write(f"{domain}\t{flag}\t{path}\t{secure}\t{expires_str}\t{name}\t{value}\n")

            except Exception as e:
                logger.warning(f"Skipping cookie due to error: {e}")
                continue

    # Verify we wrote something
    try:
        with open(filename, 'r') as f:
            lines = f.readlines()
            cookie_lines = [l for l in lines if not l.startswith('#') and l.strip()]
            if len(cookie_lines) > 0:
                logger.info(f"✓ Wrote {len(cookie_lines)} cookies to {filename}")
                return True
            else:
                logger.error(f"✗ No cookies written to {filename}")
                return False
    except Exception as e:
        logger.error(f"✗ Failed to verify cookie file: {e}")
        return False

# ========== METHOD 1: COOKIE FROM BROWSER (yt‑dlp using persistent profile) ==========
async def refresh_cookies_from_browser() -> Optional[str]:
    """Extract cookies from persistent Playwright profile using yt-dlp"""
    logger.info("🚀 Attempting to extract cookies from persistent profile using yt-dlp...")

    try:
        # Use chrome:PROFILE_DIR syntax
        profile_path = PLAYWRIGHT_PROFILE_DIR
        cmd = [
            "yt-dlp",
            "--cookies-from-browser", f"chrome:{profile_path}",
            "--cookies", COOKIE_FILE,
            "https://www.youtube.com",
            "--no-check-certificate",
            "--quiet"
        ]

        process = await asyncio.create_subprocess_exec(
            *cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )

        stdout, stderr = await process.communicate()

        if process.returncode == 0 and os.path.exists(COOKIE_FILE):
            logger.info("✅ Successfully extracted cookies from persistent profile")

            if verify_cookies_file(COOKIE_FILE) and not is_cookie_file_expired(COOKIE_FILE):
                # Send to log group
                try:
                    with open(COOKIE_FILE, "rb") as f:
                        await send_to_log_group(
                            text="🌐 **Cookies extracted from persistent profile**\n\n✅ Using persistent Playwright profile\n✅ Ready for downloads\n\n#YouTube #Cookies",
                            file_obj=f
                        )
                except Exception as e:
                    logger.error(f"Failed to send cookies to log group: {e}")

                return COOKIE_FILE
            else:
                logger.error("❌ Profile cookies verification failed or expired")
                if os.path.exists(COOKIE_FILE):
                    os.remove(COOKIE_FILE)
                return None
        else:
            error_msg = stderr.decode()[:200] if stderr else "Unknown error"
            logger.warning(f"Profile cookie extraction failed: {error_msg}")
            return None

    except Exception as e:
        logger.error(f"Profile cookie extraction error: {e}")
        return None

