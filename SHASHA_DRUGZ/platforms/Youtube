# ========== MAIN COOKIE GETTER ==========
async def get_cookies(force_refresh: bool = False) -> Optional[str]:
    """
    Get valid cookies.
    If force_refresh is True, ignore existing file and generate new ones.
    Otherwise, if existing file is valid, return its path.
    If not, try browser extraction from persistent profile first, then Playwright login.
    """
    # If not forcing refresh, check existing cookie file
    if not force_refresh and os.path.exists(COOKIE_FILE):
        if verify_cookies_file(COOKIE_FILE) and not is_cookie_file_expired(COOKIE_FILE):
            logger.info("✅ Using existing cookies file")
            return COOKIE_FILE
        else:
            logger.warning("Existing cookies file is invalid or expired, will refresh")
            if os.path.exists(COOKIE_FILE):
                os.remove(COOKIE_FILE)

    # Try browser extraction from persistent profile first
    cookie_file = await refresh_cookies_from_browser()
    if cookie_file:
        return cookie_file

    # Fallback to Playwright login
    logger.warning("Profile cookie extraction failed, falling back to Playwright login...")
    cookie_file = await refresh_cookies_playwright()
    if cookie_file:
        return cookie_file

    logger.error("All cookie generation methods failed")
    return None

# ========== AUTH ERROR DETECTION ==========
def is_auth_error(exception: Exception) -> bool:
    """Check if the exception indicates an authentication/robot check issue."""
    error_str = str(exception).lower()
    auth_indicators = [
        "sign in to confirm you're not a bot",
        "http error 401",
        "unable to extract video data",
        "this video may be inappropriate",
        "confirm your age",
        "cookie",
        "login required",
        "robot",
        "captcha",
        "recaptcha",
        "access denied",
        "forbidden"
    ]
    return any(indicator in error_str for indicator in auth_indicators)

# ========== VIDEO ID EXTRACTION ==========
def extract_video_id(url: str) -> Optional[str]:
    """
    Extract the 11-character video ID from various YouTube URL formats.
    Supports watch?v=, youtu.be/, shorts/, embed/, etc.
    """
    if not url:
        return None
    patterns = [
        r"(?:v=|youtu\.be/|shorts/|embed/)([A-Za-z0-9_-]{11})",
        r"watch\?v=([A-Za-z0-9_-]{11})",
        r"youtu\.be/([A-Za-z0-9_-]{11})",
        r"shorts/([A-Za-z0-9_-]{11})",
        r"embed/([A-Za-z0-9_-]{11})"
    ]
    for pattern in patterns:
        match = re.search(pattern, url)
        if match:
            return match.group(1)
    if 'v=' in url:
        return url.split('v=')[-1].split('&')[0]
    return None

# ========== YT-DLP OPTIONS ==========
def get_ytdlp_opts(extra_opts: dict = None, use_cookie_file: str = None) -> dict:
    """
    Get yt-dlp options. If use_cookie_file is provided, use cookiefile.
    Otherwise, use cookiesfrombrowser with the persistent profile (fallback).
    """
    base = {
        "outtmpl": "downloads/%(id)s.%(ext)s",
        "quiet": True,
        "no_warnings": True,
        "geo_bypass": True,
        "nocheckcertificate": True,
        "retries": 10,
        "fragment_retries": 10,
        "cachedir": YT_CACHE_DIR,
        "extractor_args": {
            "youtube": {
                "player_client": ["android"]  # Helps avoid bot detection
            }
        }
    }
    if use_cookie_file and os.path.exists(use_cookie_file):
        base["cookiefile"] = use_cookie_file
        logger.debug(f"Using cookiefile: {use_cookie_file}")
    else:
        # Fallback to persistent profile
        base["cookiesfrombrowser"] = ("chrome", PLAYWRIGHT_PROFILE_DIR)
        logger.debug("Using cookiesfrombrowser with persistent profile")

    # Add proxy if available
    proxy = choose_random_proxy(YTDLP_PROXY_POOL)
    if proxy:
        base["proxy"] = proxy

    if extra_opts:
        base.update(extra_opts)
    return base

# Helper to locate downloaded file
def _get_downloaded_file(video_id: str) -> Optional[str]:
    if not video_id:
        return None
    DOWNLOAD_DIR = "downloads"
    for ext in ['mp3', 'webm', 'm4a', 'opus', 'mp4', 'mkv']:
        potential = os.path.join(DOWNLOAD_DIR, f"{video_id}.{ext}")
        if os.path.exists(potential):
            return potential
    for f in os.listdir(DOWNLOAD_DIR):
        if video_id in f:
            return os.path.join(DOWNLOAD_DIR, f)
    return None

