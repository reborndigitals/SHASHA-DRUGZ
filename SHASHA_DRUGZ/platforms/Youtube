    os.makedirs(DOWNLOAD_DIR, exist_ok=True)

    # Check if file already exists
    existing = _get_downloaded_file(video_id)
    if existing:
        logger.info(f"📁 File already exists: {existing}")
        return existing

    # Ensure we have cookies
    cookie_file = await get_cookies()
    if not cookie_file:
        logger.error("No valid cookies available, cannot download")
        return None

    # Configure yt-dlp options
    if is_audio:
        ydl_opts = get_ytdlp_opts({
            "format": "bestaudio/best",
            "postprocessors": [{
                'key': 'FFmpegExtractAudio',
                'preferredcodec': 'mp3',
                'preferredquality': '192',
            }]
        }, use_cookie_file=cookie_file)
    else:
        ydl_opts = get_ytdlp_opts({
            "format": "bestvideo+bestaudio/best",
            "merge_output_format": "mp4"
        }, use_cookie_file=cookie_file)

    # Attempt download with retry on cookie-related errors
    for attempt in range(2):  # max 2 attempts (first, then refresh+retry)
        try:
            # Random sleep jitter to avoid detection
            await asyncio.sleep(random.uniform(0.5, 2.5))

            loop = asyncio.get_event_loop()
            async with DOWNLOAD_SEMAPHORE:
                with yt_dlp.YoutubeDL(ydl_opts) as ydl:
                    await loop.run_in_executor(None, lambda: ydl.extract_info(link, download=True))

            file_path = _get_downloaded_file(video_id)
            if file_path:
                logger.info(f"✅ Download successful: {file_path}")
                return file_path
            else:
                logger.error("Download completed but file not found")
                return None

        except Exception as e:
            if is_auth_error(e) and AUTO_REFRESH_COOKIES and attempt == 0:
                logger.warning(f"Download failed due to auth/robot issue: {str(e)[:200]}")
                logger.info("🔄 Refreshing cookies in background and retrying with profile fallback...")
                # Trigger background refresh
                asyncio.create_task(background_refresh_cookie())
                # Retry using profile cookies (cookiesfrombrowser) without waiting for refresh
                ydl_opts = get_ytdlp_opts({
                    "format": "bestaudio/best" if is_audio else "bestvideo+bestaudio/best",
                    "postprocessors": [{'key': 'FFmpegExtractAudio', 'preferredcodec': 'mp3', 'preferredquality': '192'}] if is_audio else None,
                    "merge_output_format": "mp4" if not is_audio else None
                }, use_cookie_file=None)  # This will use persistent profile
                continue
            else:
                logger.error(f"Download error: {str(e)[:200]}")
                return None

    return None

